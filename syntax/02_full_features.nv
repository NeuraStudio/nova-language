/* This is a 
   multi-line block comment */

// 14. MEMORY MODES (THE 3 ERAS)
// Mode 1: Managed (Default)
x = 10 // GC tracked

// Mode 2: Unsafe (Manual Memory for OS/Hardware)
unsafe {
    ptr = Nova.memory.allocate(1024)
    Nova.memory.free(ptr)
}

// Mode 3: Borrow/Own (Verified Rust-style)
function Process(own data: Buffer) { }
function Peek(borrow data: Buffer) { }
