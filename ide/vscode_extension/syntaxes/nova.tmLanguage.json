{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Nova",
    "patterns": [
        {
            "match": "\\b(function|class|return|if|else|while|for|try|catch)\\b",
            "name": "keyword.control.nova"
        },
        {
            "match": "\\b(Nova|Neura|log|show|file|network|ai|robot|database)\\b",
            "name": "entity.name.type.nova"
        },
        {
            "match": "\".*?\"",
            "name": "string.quoted.double.nova"
        },
        {
            "match": "//.*",
            "name": "comment.line.double-slash.nova"
        },
        {
            "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
            "name": "constant.numeric.nova"
        }
    ],
    "scopeName": "source.nova"
}
